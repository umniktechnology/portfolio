# ── Example variable values ───────────────────────────────────────────────────
# Copy this file to terraform.tfvars and fill in real values.
# NEVER commit terraform.tfvars — it is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

project  = "portfolio"
owner    = "hendi"
location = "eastus2"

# Run this to get your SP object ID:
# az ad sp show --id <YOUR_CLIENT_APP_ID> --query id --output tsv
sp_object_id = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

tags = {
  contact = "hendi@umniktech.com"
}
